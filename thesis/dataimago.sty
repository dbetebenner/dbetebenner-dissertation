%%
%% dataimago.sty — dissertation.ai's LaTeX package companion to `thesis.cls`.
%%
%% Provides typography hooks + the Noto Sans font setup expected by the
%% framework's default thesis class. Included via the Quarto YAML's
%% `include-in-header: [dataimago.sty]`.
%%
%% A future version will vendor a richer set of macros from
%% dataimago-design/src/latex/. For now, the file is intentionally minimal
%% so the framework default works for new users without depending on the
%% wider dataimago design system being installed.
%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dataimago}[2026/01/01 v0.1.0 dataimago.ai LaTeX support]

% XeLaTeX-only — Noto Sans requires fontspec.
\RequirePackage{fontspec}

% Minor customizations.
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.6em}

% Heading hooks (placeholder; institutions often want specific styling).
% Add \titleformat from `titlesec` if needed.

\endinput
